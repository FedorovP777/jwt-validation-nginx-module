---
Language: C
BasedOnStyle: LLVM

# Отступы (стандарт NGINX)
IndentWidth: 4
TabWidth: 4
UseTab: Never
ContinuationIndentWidth: 4

# Скобки
BreakBeforeBraces: Attach
AllowShortIfStatementsOnASingleLine: false
AllowShortFunctionsOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: false
AllowShortBlocksOnASingleLine: false

# Перенос строк
ColumnLimit: 100
BreakBeforeBinaryOperators: None
BreakAfterBinaryOperators: None
BreakBeforeTernaryOperators: true
ReflowComments: false

# Пробелы
SpaceAfterCStyleCast: true
SpaceBeforeAssignmentOperators: true
SpaceBeforeParens: ControlStatements
SpaceInEmptyParentheses: false
SpacesBeforeTrailingComments: 1
SpacesInAngles: false
SpacesInCStyleCastParentheses: false
SpacesInContainerLiterals: false
SpacesInParentheses: false
SpacesInSquareBrackets: false

# Указатели
PointerAlignment: Left

# C-специфичные настройки
AccessModifierOffset: -4     # Не влияет на C, но безопасно
SortIncludes: false
SortUsingDeclarations: false # Не влияет на C
Standard: c11                # ← ИСПРАВЛЕНО: c23 может быть не везде
IndentCaseLabels: true
CaseIndentWidth: 4
MaxEmptyLinesToKeep: 1
KeepEmptyLinesAtTheStartOfBlocks: false

# Важно для NGINX макросов
MacroBlockBegin: ""
MacroBlockEnd: ""
...